---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Festival Calendar', url: '/festivals/' },
];

const pageTitle = 'Indonesia Festival Calendar 2026';
const pageDescription = "From Bali's sacred Nyepi Day of Silence to Yogyakarta's Wayang puppet ceremonies, the Baliem Valley tribal festival in Papua, and Jakarta's explosive Independence Day — Indonesia's festivals span the world's largest archipelago.";

const festivals = [
  {
    month: 'Jan',
    monthIndex: 0,
    name: 'Nyepi Preparations — Ogoh-Ogoh Parade',
    destination: 'Bali',
    slug: 'bali',
    description: "The night before Nyepi, Bali erupts into one of its most spectacular and misunderstood events — the Ogoh-Ogoh parade, where enormous demon effigies constructed over months by each banjar (neighborhood) are paraded through the streets accompanied by gamelan percussion, fire torches, and crowds of thousands. The Ogoh-Ogoh are papier-mâché and bamboo monsters reaching three meters tall, elaborately painted and lit from within, representing malevolent spirits that must be expelled before the new year of silence begins. The parade routes circle through every neighborhood simultaneously, creating a city-wide convergence of light, sound, and craft. After the parade concludes, the effigies are burned in a purification ritual. The following morning, Nyepi begins — and the entire island goes silent.",
  },
  {
    month: 'Jan',
    monthIndex: 0,
    name: 'Bau Nyale Festival (Sasak)',
    destination: 'Lombok',
    slug: 'lombok',
    description: "Bau Nyale — literally 'catching sea worms' — is one of the most extraordinary and least-known festivals in the Indonesian archipelago, held by the Sasak people of Lombok on the southern coast near Kuta Beach. The festival celebrates the legendary Princess Mandalika, who sacrificed herself into the sea to end a conflict over her hand in marriage, and is said to reincarnate each year as the nyale sea worms that appear en masse on this specific beach at a specific low tide. Thousands of Sasak gather in the pre-dawn darkness, wading into the surf to scoop up the worms in their hands and nets — a harvest considered both auspicious and delicious, eaten raw or cooked on the beach. The exact date shifts each year based on the lunar calendar; the local government announces it months in advance.",
  },
  {
    month: 'Feb',
    monthIndex: 1,
    name: 'Cap Go Meh (Chinese New Year)',
    destination: 'Jakarta',
    slug: 'jakarta',
    description: "Cap Go Meh — the fifteenth day of the Chinese New Year — is celebrated with particular intensity in Jakarta's Glodok district, the oldest Chinatown in Southeast Asia, with dragon and lion dances, lantern festivals, and temple ceremonies that draw both the city's large Chinese-Indonesian community and curious visitors from across the capital. The celebrations in Singkawang on Kalimantan rival any Cap Go Meh in Asia for spectacle — hundreds of tatung (spirit mediums) enter trance states and perform acts of apparent self-harm while possessed, parading through the streets. Jakarta's version is more urban and accessible, with the Glodok temple complex and surrounding streets transformed into a sea of red lanterns and firecracker smoke.",
  },
  {
    month: 'Feb',
    monthIndex: 1,
    name: 'Galungan (Bali Hindu New Year)',
    destination: 'Bali',
    slug: 'bali',
    description: "Galungan is the most sacred holiday in the Balinese Hindu calendar — a ten-day celebration of the victory of dharma over adharma, during which the spirits of deceased ancestors are believed to return to visit their former homes. Every family compound erects a penjor — a towering curved bamboo pole decorated with offerings of fruit, flowers, coconut leaves, and palm sugar — along the streets, transforming every road on the island into a corridor of living sculpture. Temples are packed with worshippers in ceremonial dress, offerings are made continuously, and the island takes on a quality of sacred beauty that has no parallel. We built our Bali trip around Galungan and it was the most extraordinary thing we've ever witnessed — offerings everywhere, ceremonial dress all day, and the entire island quiet with devotion. Galungan occurs every 210 days in the Balinese Pawukon calendar.",
  },
  {
    month: 'Mar',
    monthIndex: 2,
    name: 'Nyepi — Bali Day of Silence',
    destination: 'Bali',
    slug: 'bali',
    description: "Nyepi is the Balinese New Year — and it is unlike any other holiday on Earth. For 24 hours beginning at 6am, the entire island of Bali goes completely silent. No vehicles, no lights, no noise, no work, no entertainment — not even the airport operates. The island's four traditional prohibitions (Catur Brata Penyepian) are enforced by community pecalang (traditional police) who walk the streets ensuring compliance. For Balinese Hindus, the day is spent in meditation, fasting, and silence. For tourists staying on the island, the experience is profound — Bali without traffic, without commerce, without the modern world. The stars above Ubud or Seminyak with zero light pollution for a single night are extraordinary. Nyepi date shifts annually; check the Balinese calendar for 2026.",
  },
  {
    month: 'May',
    monthIndex: 4,
    name: "Waisak (Buddha's Birthday at Borobudur)",
    destination: 'Yogyakarta',
    slug: 'yogyakarta',
    description: "Waisak — the Buddhist commemoration of Siddhartha Gautama's birth, enlightenment, and death — is celebrated at Borobudur, the world's largest Buddhist monument, in a ceremony of extraordinary beauty that draws pilgrims from across Indonesia and Buddhist communities from Asia and beyond. Thousands of orange-robed monks gather at Mendut Temple at dawn, then process to Pawon and finally to Borobudur, where a candlelit ceremony takes place as the full moon rises over the ancient stupa. The release of 1,000 floating lanterns into the night sky above the 9th-century monument is one of the most visually arresting moments any traveler can witness in Southeast Asia. Tickets for the lantern ceremony are limited and sell out months in advance — plan accordingly.",
  },
  {
    month: 'May',
    monthIndex: 4,
    name: 'Kuningan Festival (Bali)',
    destination: 'Ubud',
    slug: 'ubud',
    description: "Kuningan falls ten days after Galungan and marks the end of the sacred Balinese holiday period — the day when the ancestral spirits who descended for Galungan return to the spirit world. The day is marked by elaborate morning temple ceremonies, offerings of yellow rice (nasi kuning) symbolizing prosperity, and a final round of temple dressings and prayers before the penjor bamboo poles are dismantled. Ubud, as Bali's cultural heartland, hosts some of the most elaborate Kuningan ceremonies, with temples packed from early morning and the streets around Pura Tirta Empul and Goa Gajah especially active. The visual quality of Bali on Kuningan morning — every family in ceremonial dress, offerings carried on heads, incense smoke everywhere — is unlike any other day on the island.",
  },
  {
    month: 'Jun',
    monthIndex: 5,
    name: 'Bali Arts Festival',
    destination: 'Bali',
    slug: 'bali',
    description: "The Bali Arts Festival (Pesta Kesenian Bali) is the premier showcase of Balinese and Indonesian performing arts, running for one month at the Taman Werdhi Budaya arts center in Denpasar. Established in 1979, the festival presents daily performances of traditional Balinese dance forms — Legong, Kecak, Barong, Sanghyang — alongside gamelan competitions, Wayang Kulit shadow puppet performances, fine arts exhibitions, and crafts markets. The opening parade, in which every district of Bali sends a contingent in traditional dress, is a spectacular display of the island's cultural variety. For visitors, this is the single best opportunity to see the full range of Balinese artistic tradition presented at a high level — professional temple dancers performing forms that are rarely staged for tourists in their complete, unabbreviated versions.",
  },
  {
    month: 'Jun',
    monthIndex: 5,
    name: 'Toraja Funeral Ceremonies (Rambu Solo)',
    destination: 'Flores',
    slug: 'flores',
    description: "The Toraja people of South Sulawesi practice one of the world's most elaborate funeral traditions — Rambu Solo ceremonies that can last days or weeks, involving buffalo sacrifices, communal feasting, traditional music, and the construction of wooden tau-tau effigies of the deceased. These are not tourist events — they are genuine community ceremonies that outsiders may observe respectfully if invited or accompanied by a local guide. The peak season for Rambu Solo is June through August, when the dry season allows the outdoor gatherings and processions. The Toraja's relationship with death — including the practice of keeping deceased family members in the home for months or years before burial — reflects a worldview of extraordinary complexity. This is one of the most profound cultural experiences available to any traveler in Southeast Asia.",
  },
  {
    month: 'Jul',
    monthIndex: 6,
    name: 'Bali Spirit Festival',
    destination: 'Ubud',
    slug: 'ubud',
    description: "The Bali Spirit Festival in Ubud is one of Asia's premier yoga, dance, and music festivals — five days of workshops, performances, and community events drawing practitioners and teachers from across the global wellness world to the cultural center of Bali. The festival grounds in and around Ubud host 100+ events including yoga master classes, ecstatic dance sessions, traditional Balinese healing ceremonies, kirtan concerts, and evening performances that blend Balinese traditional arts with contemporary world music. The setting — rice fields, temple compounds, and open-air studios — elevates every session beyond what any urban wellness event can provide. The headliners have included Grammy-winning musicians and globally recognized yoga teachers; the community that assembles for a week transforms Ubud into something extraordinary.",
  },
  {
    month: 'Jul',
    monthIndex: 6,
    name: 'Yogyakarta Gamelan Festival',
    destination: 'Yogyakarta',
    slug: 'yogyakarta',
    description: "Yogyakarta's Gamelan Festival brings together ensembles from across Java and Indonesia to perform at the Kraton (Sultan's Palace), Prambanan Temple complex, and various open-air venues across the city, celebrating the bronze percussion tradition that has defined Javanese music for a thousand years. The festival typically runs over multiple evenings in July, with performances ranging from court gamelan in the palace style to contemporary experimental works that expand the tradition into new territory. The Kraton performances are particularly extraordinary — gamelan performed in the Sultan's palace courtyard at night, with the architectural context of centuries of Javanese royal culture around you, is an experience that cannot be replicated outside Java.",
  },
  {
    month: 'Aug',
    monthIndex: 7,
    name: 'Indonesian Independence Day',
    destination: 'Jakarta',
    slug: 'jakarta',
    description: "August 17 is Indonesia's Independence Day — the anniversary of Sukarno's 1945 proclamation of independence from Dutch colonial rule — and it is celebrated across 17,000 islands with a national unity that is all the more remarkable given Indonesia's extraordinary diversity of cultures, languages, and religions. The official ceremony at Istana Merdeka (Freedom Palace) in Jakarta is broadcast nationally, with military parades, flag-raising ceremonies, and speeches. Neighborhoods across Indonesia host lomba 17-an — competitions including the famous panjat pinang (greased pole climbing), sack races, and eating contests that bring communities together in genuine celebration. The atmosphere in Jakarta on August 17 is electric — flag vendors lining every street, national pride visible everywhere, and a sense of collective identity that unifies a nation of 270 million people.",
  },
  {
    month: 'Aug',
    monthIndex: 7,
    name: 'Yadnya Kasada — Tengger Ceremony, Mt. Bromo',
    destination: 'Yogyakarta',
    slug: 'yogyakarta',
    description: "The Yadnya Kasada ceremony at Mount Bromo is one of the most dramatic religious events in the world — the Tengger Hindu community gathers at the crater of the active volcano at midnight, carrying offerings of vegetables, fruits, chickens, and cash, and throws them into the caldera as an act of thanksgiving to the mountain god Brahma. The ceremony begins with prayers at the Poten temple on the Sea of Sand below the crater, then the procession climbs the 247 steps to the crater rim in darkness, arriving at the edge of the smoking caldera in the pre-dawn hours. Non-Tengger villagers positioned inside the crater attempt to catch the offerings using nets and baskets — a practice both economic and spiritual in nature. The entire scene, set against an active volcano at 2,392 meters, is beyond any description travel writing can provide.",
  },
  {
    month: 'Sep',
    monthIndex: 8,
    name: 'Jember Fashion Carnaval',
    destination: 'Yogyakarta',
    slug: 'yogyakarta',
    description: "The Jember Fashion Carnaval in East Java is one of the most spectacular street fashion events in the world — thousands of performers in elaborate, handcrafted costumes inspired by different cultural themes march through the streets of Jember in a procession that takes hours to pass. The scale of the costumes — some requiring teams of people to support their structural elements, featuring feathers, mirrors, lights, and materials sourced from across the archipelago — puts the event in a category beyond conventional fashion or carnival. International designers and fashion journalists have attended, recognizing the carnaval as a genuine creative phenomenon that emerges from a mid-sized Javanese city every September. The craftsmanship visible in the construction represents months of community work.",
  },
  {
    month: 'Sep',
    monthIndex: 8,
    name: 'Danau Toba International Cultural Festival',
    destination: 'Lake Toba',
    slug: 'lake-toba',
    description: "Lake Toba — the world's largest volcanic crater lake, located in the highlands of North Sumatra — hosts an annual international cultural festival celebrating Batak culture and the extraordinary landscape that surrounds the 100-kilometer-long lake sitting in the caldera of the world's most catastrophic known volcanic eruption, which occurred 74,000 years ago. The festival features Batak music (including the hypnotic gondang sabangunan ensemble), traditional dance, boat races on the lake, and a marketplace of Batak textiles and crafts. The Batak people — a predominantly Christian community in a predominantly Muslim region — have a musical and cultural tradition of remarkable richness that is largely unknown outside North Sumatra. The setting at Lake Toba is one of the most dramatically beautiful in all of Indonesia.",
  },
  {
    month: 'Oct',
    monthIndex: 9,
    name: 'Bali Kite Festival',
    destination: 'Bali',
    slug: 'bali',
    description: "The Bali Kite Festival at Padang Galak Beach near Sanur is one of the great overlooked spectacles in the Indonesian festival calendar — enormous traditional Balinese kites reaching 10 meters in wingspan launched into the sky above the beach, decorated with elaborate painted motifs, trailing long tails of colored fabric, and accompanied by humming bamboo instruments that produce an eerie, resonant drone audible from kilometers away. The kites are not toys but ceremonial objects — Janggan, Bebean, and Pecukan kites representing different spiritual functions, flown by teams who have trained for months in the aerodynamic management of these massive structures. The competition draws teams from across Bali, with crowds of thousands watching from the beach below as the sky fills with color and sound.",
  },
  {
    month: 'Oct',
    monthIndex: 9,
    name: 'Solo Batik Carnival',
    destination: 'Yogyakarta',
    slug: 'yogyakarta',
    description: "Solo (Surakarta) in Central Java is the ancient heart of Javanese batik — the UNESCO-recognized wax-resist fabric dyeing tradition that defines the visual culture of Java — and the Solo Batik Carnival transforms this textile heritage into a spectacular street procession where participants wear extravagant batik-based costumes of their own design through the city's historic streets. The carnival combines fashion design, batik craftsmanship, and street performance in a format that simultaneously celebrates tradition and pushes it into contemporary territory. Solo's batik workshops — some operated by families with centuries of practice — are open to visitors year-round, but the carnival provides context for understanding what batik means to Javanese cultural identity at its most creative and celebratory.",
  },
  {
    month: 'Nov',
    monthIndex: 10,
    name: 'Baliem Valley Festival (Papua)',
    destination: 'Raja Ampat',
    slug: 'raja-ampat',
    description: "The Baliem Valley Festival in the Central Highlands of Papua is one of the most extraordinary cultural events anywhere in the world — a gathering of Dani, Lani, and Yali tribes who have inhabited these remote highland valleys for millennia, staging mock warfare, traditional ceremonies, pig feasts, and displays of warrior dress that represent a living connection to a pre-contact way of life. The festival was established in 1989 as a way to share Papuan highland culture with the outside world while providing economic benefit to communities that have limited connection to Indonesia's broader economy. Participants arrive wearing traditional koteka (penis gourds), carrying spears and bows, their faces and bodies painted in ochre and charcoal. The festival is held in Wamena, accessible only by flight from Jayapura. This is one of the most remote and extraordinary travel experiences available in Southeast Asia.",
  },
  {
    month: 'Dec',
    monthIndex: 11,
    name: 'Galungan Second Cycle',
    destination: 'Bali',
    slug: 'bali',
    description: "Galungan occurs twice in the Western calendar year because the Balinese Pawukon cycle — 210 days — does not align with the 365-day solar year. The December Galungan carries the same sacred weight as the February occurrence: penjor bamboo poles lining every road, families in ceremonial white and yellow dress, temples filled with offerings, and the ancestral spirits believed to descend for their ten-day visit. December Galungan overlaps with the peak tourist season, making it paradoxically both more accessible (more flights, more infrastructure) and less intimate (more visitors sharing the experience). The early morning temple ceremonies before the tourist day begins offer the most unmediated access to the event's spiritual core. If you can be in Bali for any holiday, Galungan — in either cycle — is the one.",
  },
  {
    month: 'Dec',
    monthIndex: 11,
    name: 'Christmas in Flores & NTT',
    destination: 'Flores',
    slug: 'flores',
    description: "Flores — the 'island of flowers' in East Nusa Tenggara — is one of the most predominantly Catholic regions in Indonesia, and Christmas here bears no resemblance to Christmas in the Muslim-majority rest of the archipelago. Churches overflow for midnight mass, neighborhoods compete to build the most elaborate nativity scenes, and the celebrations incorporate elements of Florinese traditional culture — traditional woven ikat textiles worn as formal dress, ceremonial music, and community feasting — into a deeply local Christian observance that has evolved across four centuries since Portuguese missionaries arrived. Labuan Bajo, the gateway town for Komodo National Park, hosts a particularly vibrant Christmas with outdoor celebrations on the waterfront. The contrast between Flores's Catholic Christmas and Bali's Hindu calendar just one island away illustrates Indonesia's extraordinary cultural complexity.",
  },
];

const months = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];

const monthGradients = [
  'linear-gradient(135deg, #E8654A 0%, #D4A853 100%)',
  'linear-gradient(135deg, #C05299 0%, #E8654A 100%)',
  'linear-gradient(135deg, #0D7377 0%, #4DB6AC 100%)',
  'linear-gradient(135deg, #FF9800 0%, #FFC107 100%)',
  'linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%)',
  'linear-gradient(135deg, #1565C0 0%, #42A5F5 100%)',
  'linear-gradient(135deg, #6A1B9A 0%, #AB47BC 100%)',
  'linear-gradient(135deg, #BF360C 0%, #E8654A 100%)',
  'linear-gradient(135deg, #E65100 0%, #FF9800 100%)',
  'linear-gradient(135deg, #2E7D32 0%, #66BB6A 100%)',
  'linear-gradient(135deg, #1A2332 0%, #37474F 100%)',
  'linear-gradient(135deg, #B71C1C 0%, #EF5350 50%, #FFD54F 100%)',
];

const monthColors = [
  '#E8654A', '#C05299', '#0D7377', '#FF9800', '#4CAF50', '#1565C0',
  '#6A1B9A', '#BF360C', '#E65100', '#2E7D32', '#1A2332', '#B71C1C',
];

const geoLookup: Record<string, { lat: number; lng: number; label: string }> = {
  'bali': { lat: -8.4095, lng: 115.1889, label: 'Bali' },
  'yogyakarta': { lat: -7.7971, lng: 110.3688, label: 'Yogyakarta' },
  'jakarta': { lat: -6.2088, lng: 106.8456, label: 'Jakarta' },
  'ubud': { lat: -8.5069, lng: 115.2625, label: 'Ubud' },
  'flores': { lat: -8.6574, lng: 121.0794, label: 'Flores' },
  'lombok': { lat: -8.6500, lng: 116.3200, label: 'Lombok' },
  'lake-toba': { lat: 2.6831, lng: 98.8589, label: 'Lake Toba' },
  'raja-ampat': { lat: -0.5000, lng: 130.3333, label: 'Raja Ampat' },
  'nusa-penida': { lat: -8.7278, lng: 115.5444, label: 'Nusa Penida' },
};

// Build map markers
const festBySlug = new Map<string, typeof festivals>();
festivals.forEach(f => {
  const arr = festBySlug.get(f.slug) || [];
  arr.push(f);
  festBySlug.set(f.slug, arr);
});

const festMapMarkers = Array.from(festBySlug.entries())
  .map(([slug, fests]) => {
    const geo = geoLookup[slug];
    if (!geo) return null;
    return {
      lat: geo.lat,
      lng: geo.lng,
      label: geo.label,
      slug,
      color: monthColors[fests[0].monthIndex],
      url: `/destinations/${slug}/`,
      festivals: fests.map(f => ({
        name: f.name,
        month: f.month,
        destination: f.destination,
      })),
    };
  })
  .filter(Boolean);

const festGenericClips = Array.from({ length: 10 }, (_, i) => `/videos/pillar/festival-card-${i + 1}.mp4`);
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="fest-hero">
    <video class="fest-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/festivals-hero.mp4" type="video/mp4" />
    </video>
    <div class="fest-hero-gradient"></div>
    <div class="fest-hero-noise"></div>

    <div class="fest-hero-content">
      <h1 class="fest-hero-title">Indonesia Festival Calendar 2026</h1>
      <p class="fest-hero-subtitle">From Bali's sacred Nyepi Day of Silence to the Baliem Valley tribal festival in Papua — Indonesia's ceremonies span 17,000 islands and every religion on Earth.</p>
      <div class="fest-hero-meta">
        <div class="fest-hero-meta-item">
          <span class="fest-hero-meta-label">Festivals</span>
          <span class="fest-hero-meta-value">20</span>
        </div>
        <div class="fest-hero-meta-item">
          <span class="fest-hero-meta-label">Islands</span>
          <span class="fest-hero-meta-value">6</span>
        </div>
        <div class="fest-hero-meta-item">
          <span class="fest-hero-meta-label">Season</span>
          <span class="fest-hero-meta-value">Year-Round</span>
        </div>
      </div>
    </div>

    <div class="fest-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="fest-personal reveal">
    <div class="container-content">
      <blockquote class="fest-personal-quote">
        <p>Indonesia has more religious festivals than almost any country on Earth — and it makes sense when you realize it's home to the world's largest Muslim population, a Hindu heartland in Bali, Buddhist monuments in Java, and indigenous animist traditions in Sulawesi and Papua. Every island has its own ceremonial calendar. We built our Bali trip around Galungan and it was the most extraordinary thing we've ever witnessed — offerings everywhere, ceremonial dress all day, and the entire island quiet with devotion.</p>
        <cite>— Scott &amp; Jenice</cite>
      </blockquote>
    </div>
  </section>

  <!-- View Toggle -->
  <div class="container-content" style="padding-top: var(--space-2); padding-bottom: var(--space-4);">
    <div class="fest-view-toggle">
      <button class="fest-toggle-btn active" id="festBtnCalendar">Calendar</button>
      <button class="fest-toggle-btn" id="festBtnMap">Map</button>
    </div>
  </div>

  <!-- Calendar Grid -->
  <div id="festCalendarView">
  <section class="fest-calendar reveal">
    <div class="container-content">
      <h2 class="fest-section-heading">Festivals by Month</h2>
      <p class="fest-section-sub">Click any festival to explore its destination. Hover for details.</p>

      <div class="fest-month-grid">
        {months.map((monthName, i) => {
          const monthFestivals = festivals.filter(f => f.monthIndex === i);
          return (
            <div class="fest-month-card reveal">
              <div class="fest-month-header">
                <span class="fest-month-name">{monthName}</span>
                {monthFestivals.length > 0 && (
                  <span class="fest-month-count">{monthFestivals.length}</span>
                )}
              </div>
              <div class="fest-month-body">
                {monthFestivals.length > 0 ? (
                  monthFestivals.map((fest) => {
                    const idx = festivals.indexOf(fest);
                    const festVideo = festGenericClips[idx % festGenericClips.length];
                    return (
                    <a href={`/destinations/${fest.slug}/`} class="fest-entry">
                      <div class="fest-entry-media" style={`background: ${monthGradients[i]};`}>
                        <video class="fest-card-video" muted loop playsinline preload="none" data-src={festVideo}></video>
                        <div class="fest-card-scrim"></div>
                        <div class="fest-entry-media-label">{fest.month}</div>
                      </div>
                      <div class="fest-entry-info">
                        <div class="fest-entry-name">{fest.name}</div>
                        <div class="fest-entry-destination">{fest.destination}</div>
                      </div>
                      <div class="fest-entry-overlay">
                        <p class="fest-entry-desc">{fest.description}</p>
                        <span class="fest-entry-cta">Explore {fest.destination} &rarr;</span>
                      </div>
                    </a>
                  );})
                ) : (
                  <div class="fest-month-empty">No major festivals this month</div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
  </div><!-- /festCalendarView -->

  <!-- Map View -->
  <div id="festMapView" style="display:none;">
    <section style="padding: var(--space-4) 0 var(--space-8);">
      <div class="container-content">
        <div class="fest-map-container" id="festMapContainer">
          <div class="fest-map-tooltip" id="festMapTooltip">
            <div class="fest-map-tooltip-name" id="festTooltipName"></div>
            <div class="fest-map-tooltip-fests" id="festTooltipFests"></div>
          </div>
          <div id="festLeafletMap"></div>
          <div class="fest-map-legend">
            <div class="fest-map-legend-item"><div class="fest-map-legend-dot" style="background:var(--color-warm-coral);"></div>Festival location</div>
            <div class="fest-map-legend-note">Colored by month &middot; Click to explore destination</div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Bottom CTA -->
  <section class="fest-cta-section reveal">
    <div class="container-content">
      <div class="fest-cta-card">
        <h2 class="fest-cta-heading">Plan Your Indonesia Festival Trip</h2>
        <p class="fest-cta-text">Let our AI travel planner build a custom Indonesia itinerary around the festivals you want to witness — with flights between islands, accommodation, and day-by-day schedules.</p>
        <a href="/plan/" class="fest-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "What is Nyepi Day and can tourists experience it?", answer: "Nyepi is the Balinese Hindu New Year — a full 24-hour Day of Silence observed across the entire island of Bali. From 6am on Nyepi, all roads are closed, the airport shuts down, lights must be extinguished after dark, and even noise is prohibited. Tourists staying in Bali are required to remain in their hotels for the day. The night before, the spectacular Ogoh-Ogoh demon effigy parade is free to watch from the roadside. The date shifts annually based on the Balinese calendar — check exact 2026 dates before booking. Many visitors plan specifically around Nyepi for the extraordinary experience of Bali in complete silence." },
    { question: "When is Galungan in Bali?", answer: "Galungan occurs every 210 days in the Balinese Pawukon calendar, which means it falls twice in most Western calendar years. In 2026, check the official Balinese Hindu calendar (published annually by the Parisada Hindu Dharma Indonesia) for exact dates. Galungan lasts ten days, ending with Kuningan. The first day of Galungan is the most visually spectacular — penjor poles go up the night before, and by morning every road on the island is lined with the towering decorated bamboo. The entire ten-day period is extraordinary for visitors." },
    { question: "What is the Bali Arts Festival?", answer: "The Bali Arts Festival (Pesta Kesenian Bali) is a month-long performing arts showcase held annually in June at the Taman Werdhi Budaya arts center in Denpasar. Established in 1979, it presents traditional Balinese dance, gamelan competitions, Wayang Kulit shadow puppetry, fine arts, and crafts markets. The opening parade — with all districts of Bali represented in traditional dress — is one of the island's most spectacular public events. Tickets for performances are very affordable; the crafts market is free to browse. This is the best opportunity all year to see the full breadth of Balinese performing arts presented at a high level." },
    { question: "Is Indonesia safe to visit during Ramadan?", answer: "Yes — Ramadan (typically around February/March in 2026) is a thoughtful time to visit Indonesia. In Bali, the month passes largely without impact on tourists, as Bali is majority Hindu. In Java, Lombok, and Sumatra, expect reduced restaurant hours during daylight (many local warungs close from dawn to dusk), a more contemplative atmosphere, and the extraordinary spectacle of Tarawih prayers at mosques each night. Iftar (the sunset meal breaking the fast) is a communal celebration — visitors who are invited to share iftar with a local family will have an unforgettable experience. Respecting the month means dressing modestly in Muslim areas and avoiding eating or drinking in public during daylight." },
    { question: "What is the Baliem Valley Festival in Papua?", answer: "The Baliem Valley Festival is an annual cultural gathering in Wamena, Central Highlands Papua, featuring the Dani, Lani, and Yali tribes staging traditional mock warfare (complete with spears, shields, and warrior dress), pig feasts, bride-price negotiations, and ceremonial dances. It is held for three days in August. Getting there requires a flight from Jayapura (which itself requires a flight from Bali or Jakarta), making it one of Indonesia's most logistically challenging destinations. The effort is entirely worth it — this is a living connection to one of the last regions of the world where pre-contact highland culture remains a daily reality, not a museum exhibit." },
    { question: "What is Waisak at Borobudur?", answer: "Waisak (Vesak) commemorates the birth, enlightenment, and death of the Buddha and is celebrated at Borobudur — the world's largest Buddhist temple, built in the 9th century in Central Java. The ceremony involves thousands of Buddhist monks processing from Mendut Temple to Borobudur by candlelight, arriving at the main stupa as the full moon rises. The ceremony culminates in the release of 1,000 paper lanterns into the night sky above the ancient temple. Tickets for the lantern ceremony are limited and sell out months in advance; general access to the grounds for the procession requires advance booking. This is one of the most visually extraordinary events in all of Southeast Asia." },
  ]} />

