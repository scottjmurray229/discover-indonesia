---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FTCDisclosure from '../../components/FTCDisclosure.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Temple Culture', url: '/temple-culture/' },
];

const pageTitle = 'Indonesia Temple Culture — Borobudur, Prambanan & Bali Temples';
const pageDescription = 'Indonesia has some of the most extraordinary religious monuments on earth. A guide to Borobudur sunrise, Prambanan at dusk, and Bali\'s living Hindu temple culture — with practical advice on visiting each.';

const temples = [
  {
    name: 'Borobudur',
    location: 'Magelang, Central Java',
    slug: 'yogyakarta',
    description: 'The world\'s largest Buddhist monument. 9th-century, 2,672 relief panels, 504 Buddha statues. The sunrise experience from the upper terrace — watching mist clear over the Java Plain with volcanoes emerging in silhouette — is genuinely extraordinary.',
    practical: 'Book the sunrise access (max 128 visitors) at least 2 weeks ahead through the official Taman Wisata Candi website. Cost: IDR 750,000 (~$47 USD). Depart your hotel at 4am for a 5am arrival.',
    bestFor: 'Sunrise, Buddhist architecture, world heritage',
    icon: '🛕',
  },
  {
    name: 'Prambanan',
    location: 'Yogyakarta, Central Java',
    slug: 'yogyakarta',
    description: 'The 9th-century Hindu temple complex — 240 individual temples, the tallest rising 47 meters. The three main temples dedicated to Brahma, Vishnu, and Shiva are best at sunset when the stone turns orange.',
    practical: 'Combined tickets with Borobudur are available. Arrive by 4pm for the best light. The complex is 17km east of Yogyakarta — grab a GoCar or join a sunset tour. Cost: IDR 350,000 (~$22 USD).',
    bestFor: 'Hindu architecture, sunset photography, Ramayana Ballet (evening performances)',
    icon: '🏛️',
  },
  {
    name: 'Tanah Lot',
    location: 'Tabanan, Bali',
    slug: 'bali',
    description: 'The sea temple on a rock stack offshore — one of Bali\'s most photographed sights. Dramatic at sunset when the temple silhouettes against the orange sky.',
    practical: 'Entry IDR 75,000. Arrive 1 hour before sunset. Crowds are heavy July–August — midweek visits are significantly calmer. The temple itself is only accessible at low tide.',
    bestFor: 'Sunset, Bali Hindu culture, coastal scenery',
    icon: '🌊',
  },
  {
    name: 'Tirta Empul',
    location: 'Tampaksiring, Bali',
    slug: 'ubud',
    description: 'The holy spring temple where Balinese Hindus come for ritual purification. Spring water from 13th-century stone spouts feeds sacred bathing pools. One of the few temples where visitors can participate in the melukat purification ritual.',
    practical: 'Sarong required (provided). IDR 50,000 entry. If joining the purification: wear modest clothing, avoid during menstruation per Balinese custom. Arrive before 9am to see the ritual before tour groups arrive.',
    bestFor: 'Living Hindu practice, purification ritual, holy spring',
    icon: '🙏',
  },
  {
    name: 'Uluwatu',
    location: 'Pecatu, South Bali',
    slug: 'bali',
    description: 'Clifftop temple 70 meters above the Indian Ocean. Kecak fire dance performances at the temple\'s natural amphitheater at sunset — arguably more dramatic than the Ubud version due to the ocean backdrop.',
    practical: 'IDR 100,000 entry + IDR 100,000 for the Kecak dance (6pm performance). Beware the macaque monkeys — they steal glasses and phones. Sarong required.',
    bestFor: 'Ocean views, Kecak dance, cliff temple architecture',
    icon: '🦅',
  },
  {
    name: 'Besakih',
    location: 'Rendang, Bali',
    slug: 'bali',
    description: 'The Mother Temple of Bali — the largest and holiest Hindu temple on the island, built on the slopes of Mount Agung at 1,000 meters. Complex of 23 separate temples.',
    practical: 'IDR 150,000 entry. The touts at Besakih are aggressive — hire a driver who can negotiate guide access for you, or join a reputable tour. Best combined with a Mount Agung sunrise hike for serious trekkers.',
    bestFor: 'Scale, Bali Hinduism, volcanic mountain setting',
    icon: '⛰️',
  },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/temple-culture/"
>
  <div style="max-width:900px;margin:0 auto;padding:40px 20px;">
    <Breadcrumb items={breadcrumbs} />

    <h1 style="font-size:2rem;color:#1A2332;margin:24px 0 8px;">{pageTitle}</h1>
    <p style="color:#4A5568;font-size:1.1rem;line-height:1.65;margin-bottom:32px;">{pageDescription}</p>

    <section style="margin-bottom:48px;">
      <h2 style="font-size:1.4rem;color:#0D7377;margin-bottom:20px;">Indonesia's Great Temples</h2>
      <div style="display:grid;gap:24px;">
        {temples.map((temple) => (
          <div style="background:white;border:1px solid #E2E8F0;border-radius:12px;padding:24px;">
            <div style="display:flex;gap:16px;align-items:flex-start;">
              <div style="font-size:2rem;">{temple.icon}</div>
              <div style="flex:1;">
                <h3 style="font-size:1.15rem;color:#1A2332;margin:0 0 2px;">
                  <a href={`/destinations/${temple.slug}/`} style="color:#0D7377;text-decoration:none;">{temple.name}</a>
                </h3>
                <div style="font-size:0.85rem;color:#94A3B8;margin-bottom:10px;">{temple.location}</div>
                <p style="color:#4A5568;font-size:0.95rem;line-height:1.6;margin:0 0 12px;">{temple.description}</p>
                <div style="background:#F8FAFC;border-radius:8px;padding:12px;margin-bottom:10px;">
                  <div style="font-size:0.8rem;font-weight:700;color:#0D7377;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:4px;">Practical Info</div>
                  <p style="color:#4A5568;font-size:0.9rem;margin:0;">{temple.practical}</p>
                </div>
                <div style="font-size:0.85rem;color:#64748B;"><strong>Best for:</strong> {temple.bestFor}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section style="margin-bottom:48px;">
      <h2 style="font-size:1.4rem;color:#0D7377;margin-bottom:16px;">Temple Etiquette in Indonesia</h2>
      <ul style="color:#4A5568;line-height:1.8;padding-left:20px;">
        <li><strong>Sarong:</strong> Required at all Balinese Hindu temples. Usually provided at the gate, or bring your own.</li>
        <li><strong>Shoulders covered:</strong> Shoulders must be covered. A light scarf or t-shirt is sufficient.</li>
        <li><strong>Menstruation:</strong> Balinese custom asks women not to enter temples during menstruation. This is noted at most temple entrances.</li>
        <li><strong>Photography:</strong> Generally permitted in temple grounds. Never photograph during active prayer or religious ceremonies without permission.</li>
        <li><strong>Shoes:</strong> Remove shoes before entering inner temple sanctuaries. Sandals are easier to manage than lace-ups.</li>
        <li><strong>Borobudur dress code:</strong> Conservative clothing required. Tank tops, shorts, and mini-skirts are not permitted on the monument itself.</li>
      </ul>
    </section>

    <div style="margin-bottom:40px;">
      <EmailCapture leadMagnet="Indonesia Temple Culture Guide" />
    </div>

    <FTCDisclosure placement="inline" />
  </div>
</BaseLayout>
